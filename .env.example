# excalidraw-screenshot-connector configuration.
# Copy to .env (gitignored) for local runs, or fill these into your LaunchAgent.
# All values are read from the environment by server.py / install.sh.

# --- Required -------------------------------------------------------------

# Public HTTPS URL where this gateway is reachable (your tunnel domain).
# Use a domain dedicated to this connector. The Google redirect URI you register
# MUST be exactly {PUBLIC_URL}/auth/callback
PUBLIC_URL=https://your-excalidraw-shot-domain.ngrok-free.app

# Google OAuth 2.0 "Web application" client (APIs & Services > Credentials).
# If you already have an OAuth client, you can reuse it — just add this
# connector's {PUBLIC_URL}/auth/callback as an additional Authorized redirect URI.
GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxxxxxx

# Stable signing key for OAuth state/token persistence. Set a long random string
# and never change it: it keeps connected clients logged in across gateway
# restarts, and even across a GOOGLE_CLIENT_SECRET rotation. Generate one with:
#   python3 -c "import secrets; print(secrets.token_urlsafe(48))"
# If left unset, the key is derived from GOOGLE_CLIENT_SECRET, so a restart after a
# fastmcp upgrade or a secret rotation silently logs everyone out (re-auth needed).
JWT_SIGNING_KEY=

# Access control: email-only. Exact addresses, case-insensitive, comma-separated
# for more than one. Required, or the server refuses to start (fail closed).
ALLOWED_EMAILS=you@example.com

# --- Optional -------------------------------------------------------------

# ms to wait for the Live-collaboration room to sync its scene after the canvas
# mounts. Bump for large/slow drawings.
# ROOM_SYNC_MS=6000

# Which MCP-client redirect URIs to accept during Dynamic Client Registration
# (comma-separated fnmatch globs). Defaults to Claude's hosts; widen only if you
# connect a different client (e.g. add http://localhost:* for a local dev client).
# ALLOWED_REDIRECT_URI_PATTERNS=https://claude.ai/*,https://claude.com/*

# HOST=127.0.0.1          # gateway bind address (keep loopback; expose via the tunnel)
# PORT=8040               # local port the gateway listens on
# EMAIL_CLAIM=email       # which OAuth claim carries the email address
# DEBUG=false             # log the auth decision (email + verified flag) per request
